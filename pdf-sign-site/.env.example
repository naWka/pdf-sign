# Companion site config. Copy to .env.local. All NEXT_PUBLIC_* values are PUBLIC
# (they reach the browser) — only put public tokens/URLs here, never secrets.

# Chrome Web Store listing URL (fill in after the listing is live).
NEXT_PUBLIC_STORE_URL=https://chromewebstore.google.com/detail/YOUR_EXTENSION_ID

# Paddle Billing — client-side token + the lifetime price id.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_or_test_client_token
NEXT_PUBLIC_PADDLE_PRICE_ID=pri_...
# 'sandbox' while testing, 'production' when live.
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Supabase function base (for the success page to fetch the license token).
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=https://YOUR-PROJECT.supabase.co/functions/v1

# Displayed lifetime price (owner-set; the real charge comes from Paddle).
NEXT_PUBLIC_PRICE_DISPLAY=$19 once
