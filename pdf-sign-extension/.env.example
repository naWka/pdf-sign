# Extension build-time config. Copy to `.env` and fill in.
# These are PUBLIC values only (URLs, client token, price id). Never put secret
# keys here — the extension bundle is shippable and inspectable.

# Companion site (landing, pricing, privacy, success). No trailing slash.
VITE_SITE_URL=https://signfillpdf.com

# Where "Unlock lifetime" opens (usually the pricing/checkout page on the site).
VITE_CHECKOUT_URL=https://signfillpdf.com/pricing

# Public endpoint that returns only { status } for a license id (best-effort
# online re-check). Served by the site / a Supabase function.
VITE_LICENSE_STATUS_URL=https://signfillpdf.com/api/license/status

# NOTE: the Ed25519 PUBLIC key is NOT set here. It is compiled into the bundle
# via src/license/public-key.ts (see the HUMAN-TODO in that file).
