# Supabase Edge Function secrets. Set these with:
#   supabase secrets set --env-file supabase/.env
# NEVER commit the filled-in .env. These are server-only; none reach the client.

# From Supabase project settings (service_role is server-only, full access).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Paddle webhook signing secret (Paddle > Notifications > your destination).
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# Ed25519 PRIVATE key (PKCS8 DER, base64). Server-only — its public counterpart
# is bundled in the extension. Generate:
#   openssl genpkey -algorithm ed25519 -out private.pem
#   openssl pkey -in private.pem -outform DER | base64   # -> paste below
LICENSE_PRIVATE_KEY_B64=BASE64_PKCS8_ED25519_PRIVATE_KEY
